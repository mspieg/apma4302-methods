# petsc-options for a fieldsplit preconditioner using  direct solver on each laplacian block
-ksp_monitor 
-da_refine 8
-ksp_type fgmres
-ksp_rtol 1.e-6
-ksp_atol 1.e-10
-pc_type fieldsplit
-pc_fieldsplit_type multiplicative
-fieldsplit_vorticity_pc_type lu
-fieldsplit_streamfunction_pc_type lu
-fieldsplit_vorticity_pc_factor_mat_solver_type mumps
-fieldsplit_streamfunction_pc_factor_mat_solver_type mumps
